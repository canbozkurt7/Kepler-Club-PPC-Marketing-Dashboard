# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ppc_dashboard
REDIS_URL=redis://localhost:6379

# Supabase (used by seed_data.py and the init_db_*/verify_schema scripts).
# The service_role key has full admin access and bypasses Row Level Security —
# keep it secret, never commit the real value. The anon key is safe to expose.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Ads API Credentials
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id_here
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=917-055-6639

# Meta Ads API Credentials (Phase 2)
META_ACCESS_TOKEN=your_meta_token_here

# Yandex Ads API Credentials (Yandex Direct OAuth token)
YANDEX_API_TOKEN=your_yandex_token_here
# Only needed for agency tokens — the advertiser account login to report on
YANDEX_CLIENT_LOGIN=

# Microsoft Ads (Bing Ads) API Credentials
MICROSOFT_DEVELOPER_TOKEN=your_developer_token_here
MICROSOFT_CUSTOMER_ID=your_customer_id_here
# Optional: Client ID and Secret for OAuth (currently using Developer Token auth)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL_TO=marketing@keplerclub.com
ALERT_EMAIL_FROM=noreply@keplerclub.com

# Microsoft Clarity API
CLARITY_API_TOKEN=your_clarity_token_here

# Application Settings
DEBUG=false
APP_NAME=Kepler PPC Dashboard
